#include <bits/stdc++.h>
using namespace std;

struct Node {
    string addr;
    int val;
    string next;
};

int main() {
    string head;
    int n, k;
    cin >> head >> n >> k;

    // 1. 用 map 存链表：地址 → (值, 下一地址)
    map<string, pair<int, string>> mp;
    for (int i = 0; i < n; i++) {
        string a, ne;
        int v;
        cin >> a >> v >> ne;
        mp[a] = {v, ne};
    }

    // 2. 从起点遍历，收集所有有效节点
    vector<Node> list;
    string cur = head;
    while (cur != "-1" && mp.count(cur)) {
        list.push_back({cur, mp[cur].first, mp[cur].second});
        cur = mp[cur].second;
    }

    // 3. 分三类
    vector<Node> neg, low, high;
    for (auto &node : list) {
        if (node.val < 0)       neg.push_back(node);
        else if (node.val <= k) low.push_back(node);
        else                    high.push_back(node);
    }

    // 4. 合并
    vector<Node> result;
    result.insert(result.end(), neg.begin(), neg.end());
    result.insert(result.end(), low.begin(), low.end());
    result.insert(result.end(), high.begin(), high.end());

    // 5. 输出
    for (int i = 0; i < result.size(); i++) {
        cout << result[i].addr << " " << result[i].val << " ";
        if (i == result.size() - 1)
            cout << "-1" << endl;
        else
            cout << result[i + 1].addr << endl;
    }

    return 0;
}
